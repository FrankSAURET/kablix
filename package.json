{
  "name": "kablix",
  "displayName": "Kablix",
  "version": "0.5.0",
  "description": "Une application gauloise de simulation de microcontrôleurs (Arduino Uno / Raspberry Pi Pico) directement dans VS Code, 100% offline.",
  "publisher": "franksauret",
  "license": "MIT",
  "icon": "Kablix.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/franksauret/kablix"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Education",
    "Visualization",
    "Other"
  ],
  "keywords": [
    "arduino",
    "raspberry pi pico",
    "microcontroller",
    "simulator",
    "avr",
    "offline"
  ],
  "main": "./dist/extension.js",
  "activationEvents": [],
  "contributes": {
    "commands": [
      {
        "command": "kablix.openSimulator",
        "title": "Kablix : Ouvrir le simulateur",
        "category": "Kablix"
      },
      {
        "command": "kablix.compileAndRun",
        "title": "Kablix : Compiler & exécuter le fichier actif",
        "category": "Kablix"
      },
      {
        "command": "kablix.loadWorkspaceArtifact",
        "title": "Kablix : Charger l'artefact compilé du workspace",
        "category": "Kablix"
      }
    ],
    "configuration": {
      "title": "Kablix",
      "properties": {
        "kablix.micropythonUf2": {
          "type": "string",
          "default": "",
          "description": "Chemin (absolu ou relatif au workspace) du firmware MicroPython .uf2 utilisé pour exécuter les fichiers .py sur le Pico simulé. Laisser vide pour détecter automatiquement micropython*.uf2 / RPI_PICO*.uf2 dans le workspace."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run build",
    "build": "node esbuild.js --production",
    "watch": "node esbuild.js --watch",
    "build:firmware": "node scripts/build-firmware.mjs",
    "typecheck": "tsc --noEmit",
    "verify": "node scripts/verify-sim.mjs",
    "verify:compiler": "node scripts/verify-compiler.mjs",
    "verify:diagram": "node scripts/verify-diagram.mjs",
    "verify:uf2": "node scripts/verify-uf2.mjs",
    "verify:micropython": "node scripts/verify-micropython.mjs",
    "verify:all": "npm run verify && npm run verify:compiler && npm run verify:diagram && npm run verify:uf2 && npm run verify:micropython",
    "package": "vsce package --no-dependencies"
  },
  "dependencies": {
    "@wokwi/elements": "1.9.2",
    "avr8js": "0.21.0",
    "rp2040js": "1.3.2"
  },
  "devDependencies": {
    "@types/node": "20.11.0",
    "@types/vscode": "1.85.0",
    "@vscode/vsce": "3.9.2",
    "esbuild": "0.28.0",
    "typescript": "6.0.3"
  }
}
