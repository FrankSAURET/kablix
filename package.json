{
  "name": "microsim-vscode",
  "displayName": "MicroSim",
  "version": "0.3.0",
  "description": "Simulation de microcontrôleurs (Arduino Uno / Raspberry Pi Pico) directement dans VS Code, 100% offline.",
  "publisher": "franksauret",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/franksauret/microsim-vscode"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Education",
    "Visualization",
    "Other"
  ],
  "keywords": [
    "arduino",
    "raspberry pi pico",
    "microcontroller",
    "simulator",
    "avr",
    "offline"
  ],
  "main": "./dist/extension.js",
  "activationEvents": [],
  "contributes": {
    "commands": [
      {
        "command": "microsim.openSimulator",
        "title": "MicroSim : Ouvrir le simulateur",
        "category": "MicroSim"
      },
      {
        "command": "microsim.compileAndRun",
        "title": "MicroSim : Compiler & exécuter le fichier actif",
        "category": "MicroSim"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run build",
    "build": "node esbuild.js --production",
    "watch": "node esbuild.js --watch",
    "build:firmware": "node scripts/build-firmware.mjs",
    "typecheck": "tsc --noEmit",
    "verify": "node scripts/verify-sim.mjs",
    "verify:compiler": "node scripts/verify-compiler.mjs",
    "verify:diagram": "node scripts/verify-diagram.mjs",
    "verify:all": "npm run verify && npm run verify:compiler && npm run verify:diagram",
    "package": "vsce package --no-dependencies"
  },
  "dependencies": {
    "@wokwi/elements": "1.9.2",
    "avr8js": "0.21.0",
    "rp2040js": "1.3.2"
  },
  "devDependencies": {
    "@types/node": "20.11.0",
    "@types/vscode": "1.85.0",
    "@vscode/vsce": "3.9.2",
    "esbuild": "0.28.0",
    "typescript": "6.0.3"
  }
}
