{
  "name": "kablix",
  "displayName": "Kablix",
  "version": "2026.6.5",
  "description": "%kablix.description%",
  "publisher": "franksauret",
  "author": {
    "name": "electropol.fr",
    "url": "https://electropol.fr"
  },
  "license": "MIT",
  "icon": "Kablix.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/franksauret/kablix"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Education",
    "Visualization",
    "Other"
  ],
  "keywords": [
    "arduino",
    "raspberry pi pico",
    "microcontroller",
    "simulator",
    "avr",
    "offline"
  ],
  "main": "./dist/extension.js",
  "activationEvents": [
    "onStartupFinished"
  ],
  "contributes": {
    "commands": [
      {
        "command": "kablix.openSimulator",
        "title": "%kablix.cmd.openSimulator%",
        "category": "Kablix"
      },
      {
        "command": "kablix.compileAndRun",
        "title": "%kablix.cmd.compileAndRun%",
        "category": "Kablix"
      },
      {
        "command": "kablix.loadWorkspaceArtifact",
        "title": "%kablix.cmd.loadWorkspaceArtifact%",
        "category": "Kablix"
      },
      {
        "command": "kablix.saveProject",
        "title": "%kablix.cmd.saveProject%",
        "category": "Kablix"
      },
      {
        "command": "kablix.openProject",
        "title": "%kablix.cmd.openProject%",
        "category": "Kablix"
      },
      {
        "command": "kablix.exportWokwiDiagram",
        "title": "%kablix.cmd.exportWokwiDiagram%",
        "category": "Kablix"
      },
      {
        "command": "kablix.importWokwiDiagram",
        "title": "%kablix.cmd.importWokwiDiagram%",
        "category": "Kablix"
      },
      {
        "command": "kablix.checkLibraryUpdates",
        "title": "%kablix.cmd.checkLibraryUpdates%",
        "category": "Kablix"
      },
      {
        "command": "kablix.openHelp",
        "title": "%kablix.cmd.openHelp%",
        "category": "Kablix"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "kablix",
          "title": "Kablix",
          "icon": "media/activity-icon.png"
        }
      ]
    },
    "views": {
      "kablix": [
        {
          "id": "kablix.home",
          "name": "%kablix.view.home%"
        }
      ]
    },
    "viewsWelcome": [
      {
        "view": "kablix.home",
        "contents": "%kablix.welcome%"
      }
    ],
    "configuration": {
      "title": "Kablix",
      "properties": {
        "kablix.micropythonUf2": {
          "type": "string",
          "default": "",
          "description": "%kablix.config.micropythonUf2%"
        },
        "kablix.checkUpdatesOnStartup": {
          "type": "boolean",
          "default": false,
          "description": "%kablix.config.checkUpdatesOnStartup%"
        },
        "kablix.arduinoCliPath": {
          "type": "string",
          "default": "",
          "description": "%kablix.config.arduinoCliPath%"
        },
        "kablix.toolchainPath": {
          "type": "string",
          "default": "",
          "description": "%kablix.config.toolchainPath%"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run build",
    "build": "node esbuild.js --production",
    "watch": "node esbuild.js --watch",
    "build:firmware": "node scripts/build-firmware.mjs",
    "typecheck": "tsc --noEmit",
    "verify": "node scripts/verify-sim.mjs",
    "verify:compiler": "node scripts/verify-compiler.mjs",
    "verify:diagram": "node scripts/verify-diagram.mjs",
    "verify:uf2": "node scripts/verify-uf2.mjs",
    "verify:micropython": "node scripts/verify-micropython.mjs",
    "verify:wokwi": "node scripts/verify-wokwi.mjs",
    "verify:all": "npm run verify && npm run verify:compiler && npm run verify:diagram && npm run verify:uf2 && npm run verify:micropython && npm run verify:wokwi",
    "package": "vsce package --no-dependencies"
  },
  "dependencies": {
    "@wokwi/elements": "1.9.2",
    "avr8js": "0.21.0",
    "jszip": "^3.10.1",
    "rp2040js": "1.3.2"
  },
  "devDependencies": {
    "@types/node": "20.11.0",
    "@types/vscode": "1.85.0",
    "@vscode/vsce": "3.9.2",
    "esbuild": "0.28.0",
    "typescript": "6.0.3"
  },
  "l10n": "./l10n"
}
